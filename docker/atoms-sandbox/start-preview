#!/usr/bin/env bash
set -euo pipefail

WORKSPACE_ROOT="/workspace"
CONTRACT_PATH="${WORKSPACE_ROOT}/.atoms/preview.json"
FRONTEND_LOG="/tmp/atoms-preview-frontend.log"
BACKEND_LOG="/tmp/atoms-preview-backend.log"

resolve_frontend_root() {
  local workspace_root="$1"

  if [[ -f "${workspace_root}/package.json" ]]; then
    echo "${workspace_root}"
    return 0
  fi

  if [[ -f "${workspace_root}/app/frontend/package.json" ]]; then
    echo "${workspace_root}/app/frontend"
    return 0
  fi

  echo "${workspace_root}"
}

kill_listeners_on_port() {
  local port="$1"
  mapfile -t PORT_PIDS < <(python3 - "${port}" <<'PY'
import os
import sys

port = int(sys.argv[1])
inodes = set()

for proc_net in ("/proc/net/tcp", "/proc/net/tcp6"):
    try:
        with open(proc_net, "r", encoding="utf-8") as fh:
            next(fh)
            for line in fh:
                cols = line.split()
                if len(cols) < 10:
                    continue
                local_addr = cols[1]
                state = cols[3]
                inode = cols[9]
                if state != "0A":
                    continue
                if int(local_addr.split(":")[1], 16) == port:
                    inodes.add(inode)
    except FileNotFoundError:
        continue

for pid in sorted(filter(str.isdigit, os.listdir("/proc")), key=int):
    fd_dir = f"/proc/{pid}/fd"
    try:
        for fd in os.listdir(fd_dir):
            try:
                target = os.readlink(f"{fd_dir}/{fd}")
            except OSError:
                continue
            if target.startswith("socket:[") and target[8:-1] in inodes:
                print(pid)
                break
    except OSError:
        continue
PY
  )

  if [[ ${#PORT_PIDS[@]} -gt 0 ]]; then
    kill "${PORT_PIDS[@]}" || true
    sleep 1
  fi
}

install_node_deps_if_needed() {
  if [[ ! -f "${FRONTEND_ROOT}/package.json" ]]; then
    return
  fi

  if [[ ! -d "${FRONTEND_ROOT}/node_modules" ]] || [[ "${FRONTEND_ROOT}/package.json" -nt "${FRONTEND_ROOT}/node_modules" ]] || [[ -f "${FRONTEND_ROOT}/pnpm-lock.yaml" && "${FRONTEND_ROOT}/pnpm-lock.yaml" -nt "${FRONTEND_ROOT}/node_modules" ]]; then
    (
      cd "${FRONTEND_ROOT}"
      pnpm install --prefer-offline
    )
  fi
}

resolve_backend_root() {
  local workspace_root="$1"
  if [[ -f "${workspace_root}/app/backend/requirements.txt" ]] || [[ -f "${workspace_root}/app/backend/pyproject.toml" ]]; then
    echo "${workspace_root}/app/backend"
    return 0
  fi
  if [[ -f "${workspace_root}/backend/requirements.txt" ]] || [[ -f "${workspace_root}/backend/pyproject.toml" ]]; then
    echo "${workspace_root}/backend"
    return 0
  fi
  echo ""
}

ensure_backend_venv() {
  local backend_root="$1"
  local venv_dir="${backend_root}/.venv"
  if [[ ! -x "${venv_dir}/bin/python" ]]; then
    echo "start-preview: creating venv at ${venv_dir}" >&2
    python3 -m venv "${venv_dir}"
  else
    echo "start-preview: reusing existing venv at ${venv_dir}" >&2
  fi
  if [[ -f "${backend_root}/requirements.txt" ]]; then
    if [[ -x "${venv_dir}/bin/pip" ]]; then
      echo "start-preview: installing requirements via pip" >&2
      "${venv_dir}/bin/pip" install -q -r "${backend_root}/requirements.txt"
    else
      echo "start-preview: pip not found in venv (uv-managed), using uv pip install" >&2
      uv pip install -q --python "${venv_dir}/bin/python" -r "${backend_root}/requirements.txt"
    fi
  fi
}

normalize_backend_command() {
  local backend_root="$1"
  local command="$2"
  local venv_python="${backend_root}/.venv/bin/python"
  if [[ "${command}" == *"uv run uvicorn "* ]]; then
    local import_target
    import_target="$(python3 - "${command}" <<'PY'
import sys, re
m = re.search(r'uv run uvicorn\s+(\S+)', sys.argv[1])
print(m.group(1) if m else "")
PY
)"
    local normalized="cd ${backend_root} && ${venv_python} -m uvicorn ${import_target} --host 0.0.0.0 --port 8000"
    echo "start-preview: normalized backend command: ${normalized}" >&2
    echo "${normalized}"
    return 0
  fi
  echo "start-preview: backend command unchanged: ${command}" >&2
  echo "${command}"
}

is_standard_pnpm_dev_command() {
  local command="$1"
  local trimmed="${command#"${command%%[![:space:]]*}"}"

  if [[ "${trimmed}" == "pnpm run dev -- --host 0.0.0.0 --port 3000" ]] || [[ "${trimmed}" == "pnpm run dev"* ]]; then
    return 0
  fi

  if [[ "${trimmed}" == cd*"&& pnpm run dev"* ]]; then
    return 0
  fi

  return 1
}

if [[ ! -f "${CONTRACT_PATH}" ]]; then
  exec /usr/local/bin/start-dev
fi

eval "$(python3 - <<'PY'
import json
import shlex
from pathlib import Path

payload = json.loads(Path("/workspace/.atoms/preview.json").read_text(encoding="utf-8"))

def service_config(value, default_healthcheck_path):
    if value is None:
        return None
    if isinstance(value, str):
        return {"command": value, "healthcheck_path": default_healthcheck_path}
    if isinstance(value, dict):
        return {
            "command": value["command"],
            "healthcheck_path": value.get("healthcheck_path", default_healthcheck_path),
        }
    raise TypeError(f"Unsupported preview service config: {type(value)!r}")

frontend = service_config(payload["frontend"], "/")
backend = service_config(payload.get("backend"), payload.get("healthcheck", "/health"))

print(f'FRONTEND_COMMAND={shlex.quote(frontend["command"])}')
print(f'FRONTEND_HEALTHCHECK_PATH={shlex.quote(frontend["healthcheck_path"])}')
if backend:
    print(f'BACKEND_COMMAND={shlex.quote(backend["command"])}')
    print(f'BACKEND_HEALTHCHECK_PATH={shlex.quote(backend["healthcheck_path"])}')
PY
)"

cd "${WORKSPACE_ROOT}"

export ATOMS_PREVIEW_FRONTEND_BASE="${ATOMS_PREVIEW_FRONTEND_BASE:-/}"
export ATOMS_PREVIEW_BACKEND_BASE="${ATOMS_PREVIEW_BACKEND_BASE:-/api}"
export VITE_ATOMS_PREVIEW_FRONTEND_BASE="${VITE_ATOMS_PREVIEW_FRONTEND_BASE:-${ATOMS_PREVIEW_FRONTEND_BASE}}"
export VITE_ATOMS_PREVIEW_BACKEND_BASE="${VITE_ATOMS_PREVIEW_BACKEND_BASE:-${ATOMS_PREVIEW_BACKEND_BASE}}"

FRONTEND_ROOT="$(resolve_frontend_root "${WORKSPACE_ROOT}")"

install_node_deps_if_needed

if is_standard_pnpm_dev_command "${FRONTEND_COMMAND}"; then
  /usr/local/bin/start-dev >"${FRONTEND_LOG}" 2>&1
else
  kill_listeners_on_port 3000
  (
    cd "${FRONTEND_ROOT}"
    nohup bash -lc "${FRONTEND_COMMAND}" >"${FRONTEND_LOG}" 2>&1 &
  )
fi

BACKEND_ROOT=""
if [[ -n "${BACKEND_COMMAND:-}" ]]; then
  BACKEND_ROOT="$(resolve_backend_root "${WORKSPACE_ROOT}")"
  if [[ -n "${BACKEND_ROOT}" ]]; then
    ensure_backend_venv "${BACKEND_ROOT}"
    BACKEND_COMMAND="$(normalize_backend_command "${BACKEND_ROOT}" "${BACKEND_COMMAND}")"
  fi
fi

if [[ -n "${BACKEND_COMMAND:-}" ]]; then
  kill_listeners_on_port 8000
  nohup bash -lc "${BACKEND_COMMAND}" >"${BACKEND_LOG}" 2>&1 &
fi

echo "start-preview: frontend_command=${FRONTEND_COMMAND}" >&2
echo "start-preview: backend_command=${BACKEND_COMMAND:-<none>}" >&2
echo "start-preview: launched preview services"
