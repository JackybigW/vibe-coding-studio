#!/usr/bin/env bash
# Idempotent dev-server launcher for atoms sandboxes.
# Expects: bind-mounted project at /workspace (or ATOMS_WORKSPACE_ROOT), ATOMS_PROJECT_ID env var.
# Produces: detached `pnpm run dev` listening on 0.0.0.0:3000 with the correct
# Vite --base so assets resolve through the backend preview proxy.
set -euo pipefail

PROJECT_ID="${ATOMS_PROJECT_ID:-}"
if [[ -z "${PROJECT_ID}" ]]; then
    echo "start-dev: ATOMS_PROJECT_ID env var is required" >&2
    exit 2
fi

resolve_frontend_root() {
    local workspace_root="$1"

    if [[ -f "${workspace_root}/package.json" ]]; then
        echo "${workspace_root}"
        return 0
    fi

    if [[ -f "${workspace_root}/app/frontend/package.json" ]]; then
        echo "${workspace_root}/app/frontend"
        return 0
    fi

    echo "${workspace_root}"
}

WORKSPACE_ROOT="${ATOMS_WORKSPACE_ROOT:-/workspace}"
FRONTEND_ROOT="$(resolve_frontend_root "${WORKSPACE_ROOT}")"
BASE_PATH="${ATOMS_PREVIEW_FRONTEND_BASE:-/api/v1/workspace-runtime/projects/${PROJECT_ID}/preview/}"
LOG_FILE="/tmp/atoms-dev.log"

cd "${FRONTEND_ROOT}"

if [[ ! -f "package.json" ]]; then
    echo "start-dev: package.json not found under ${WORKSPACE_ROOT} or ${WORKSPACE_ROOT}/app/frontend; nothing to start" >&2
    exit 3
fi

# Install deps if missing or if lockfile is newer than node_modules.
if [[ ! -d "node_modules" ]] || [[ "package.json" -nt "node_modules" ]] || [[ -f "pnpm-lock.yaml" && "pnpm-lock.yaml" -nt "node_modules" ]]; then
    pnpm install --prefer-offline
fi

# Kill any previous listener on :3000 inside this container.
PORT_3000_PIDS=()
if [[ -d "/proc" ]]; then
    while IFS= read -r pid; do
        if [[ -n "${pid}" ]]; then
            PORT_3000_PIDS+=("${pid}")
        fi
    done < <(python3 - 3000 <<'PY'
import os
import sys

port = int(sys.argv[1])
inodes = set()

for proc_net in ("/proc/net/tcp", "/proc/net/tcp6"):
    try:
        with open(proc_net, "r", encoding="utf-8") as fh:
            next(fh)
            for line in fh:
                cols = line.split()
                if len(cols) < 10:
                    continue
                local_addr = cols[1]
                state = cols[3]
                inode = cols[9]
                if state != "0A":
                    continue
                if int(local_addr.split(":")[1], 16) == port:
                    inodes.add(inode)
    except FileNotFoundError:
        continue

for pid in sorted(filter(str.isdigit, os.listdir("/proc")), key=int):
    fd_dir = f"/proc/{pid}/fd"
    try:
        for fd in os.listdir(fd_dir):
            try:
                target = os.readlink(f"{fd_dir}/{fd}")
            except OSError:
                continue
            if target.startswith("socket:[") and target[8:-1] in inodes:
                print(pid)
                break
    except OSError:
        continue
PY
    )
fi
if [[ ${#PORT_3000_PIDS[@]} -gt 0 ]]; then
    kill "${PORT_3000_PIDS[@]}" || true
    sleep 1
fi

# Detach with nohup so the dev server survives the `docker exec` that started it.
nohup pnpm run dev \
    --host 0.0.0.0 \
    --port 3000 \
    --base "${BASE_PATH}" \
    >"${LOG_FILE}" 2>&1 &

DEV_PID=$!
echo "start-dev: launched pnpm run dev (pid=${DEV_PID}) base=${BASE_PATH}"
disown "${DEV_PID}" 2>/dev/null || true
