# ============================================================
# atoms – environment variables template
# Copy this to .env and fill in your values
# ============================================================

# ----- Database -----
# Local (SQLite):  DATABASE_URL=sqlite:///./atoms.db
# Server (Postgres): DATABASE_URL=postgresql://atoms_user:PASSWORD@localhost/atoms_db
DATABASE_URL=sqlite:///./atoms.db

# ----- JWT -----
JWT_SECRET_KEY=change-me-to-a-random-secret-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ----- AI (MiniMax via OpenAI-compatible API) -----
APP_AI_BASE_URL=https://api.minimax.chat/v1
APP_AI_KEY=your-minimax-api-key-here
# Default model (overridable per request)
APP_AI_DEFAULT_MODEL=MiniMax-M2.7

# ----- Additional OpenAI-compatible model providers -----
APP_AI_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
APP_AI_MIMO_KEY=your-mimo-api-key-here
APP_AI_MIMO_MODEL=mimo-v2.5-pro

APP_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
APP_AI_DEEPSEEK_KEY=your-deepseek-api-key-here
APP_AI_DEEPSEEK_MODEL=deepseek-v4-pro

# ----- OIDC (login provider) -----
OIDC_ISSUER_URL=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_SCOPE="openid email profile"

# ----- App URLs -----
FRONTEND_URL=http://localhost:3000
PYTHON_BACKEND_URL=http://localhost:8000

# ----- Environment -----
ENVIRONMENT=dev
