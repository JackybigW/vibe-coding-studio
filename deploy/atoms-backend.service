[Unit]
Description=Vibe Coding Studio Backend (FastAPI)
After=network.target postgresql.service

[Service]
Type=exec
WorkingDirectory=/home/ubuntu/atoms/app/backend
EnvironmentFile=/home/ubuntu/atoms/app/.env
ExecStart=/root/miniconda3/envs/atoms/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
